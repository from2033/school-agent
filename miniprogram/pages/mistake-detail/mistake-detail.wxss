.subject-badge { width: 80rpx; height: 80rpx; border-radius: 22rpx; color: #fff; font-size: 24rpx;
  font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

.d-top { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.d-top__body { flex: 1; min-width: 0; }
.d-top__topic { font-size: 30rpx; font-weight: 600; }

.d-img { width: 100%; border-radius: 24rpx; }
.d-img-placeholder { height: 280rpx; background: var(--muted); border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center; font-size: 26rpx; gap: 10rpx; }
.ic20w { width: 32rpx; height: 32rpx; }
.ic24 { width: 32rpx; height: 32rpx; }
.ic44 { width: 44rpx; height: 44rpx; }

.tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 24rpx; }
.tag { font-size: 22rpx; background: var(--secondary); color: var(--primary); padding: 6rpx 18rpx; border-radius: 999rpx; }

.d-label { display: flex; align-items: center; gap: 12rpx; font-weight: 600; font-size: 28rpx; margin-bottom: 14rpx; }
.d-label__icon { font-size: 30rpx; }
.d-text { font-size: 28rpx; line-height: 1.7; color: var(--card-fg); }

/* 重点关注 —— 等级色标签 */
.focus-wrap { display: flex; flex-direction: column; gap: 14rpx; }
.focus {
  display: flex; align-items: center; gap: 14rpx;
  padding: 18rpx 22rpx; border-radius: 20rpx;
}
.focus__dot { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.focus__txt { flex: 1; font-size: 27rpx; font-weight: 500; }
.focus__lvl { font-size: 20rpx; font-weight: 600; padding: 4rpx 14rpx; border-radius: 999rpx; }
.focus--high { background: #fef2f2; }
.focus--high .focus__dot { background: #dc2626; }
.focus--high .focus__txt { color: #b91c1c; }
.focus--high .focus__lvl { background: #fee2e2; color: #dc2626; }
.focus--medium { background: #fffbeb; }
.focus--medium .focus__dot { background: #d97706; }
.focus--medium .focus__txt { color: #b45309; }
.focus--medium .focus__lvl { background: #fef3c7; color: #d97706; }
.focus--low { background: #f0fdfa; }
.focus--low .focus__dot { background: #0d9488; }
.focus--low .focus__txt { color: #0f766e; }
.focus--low .focus__lvl { background: #ccfbf1; color: #0f766e; }

/* 分步建议 */
.step { display: flex; gap: 18rpx; align-items: flex-start; margin-bottom: 18rpx; }
.step:last-child { margin-bottom: 0; }
.step__no {
  width: 40rpx; height: 40rpx; border-radius: 50%; flex-shrink: 0;
  background: var(--secondary); color: var(--primary);
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.step__txt { flex: 1; font-size: 27rpx; line-height: 1.6; padding-top: 4rpx; }

.btn-secondary {
  margin-top: 20rpx; background: var(--secondary); color: var(--primary);
  border-radius: 32rpx; padding: 28rpx; font-size: 30rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
}
.ic20 { width: 34rpx; height: 34rpx; }
