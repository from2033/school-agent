<view class="tab-pad">
  <view class="header">
    <view class="header__title">远程打印</view>
    <view class="header__sub">选择内容，一键发送到打印机</view>
  </view>

  <view class="section-pad gap" style="padding-top: 24rpx;">
    <!-- 打印机状态 -->
    <view class="card printer">
      <view class="printer__icon"><image class="ic40" src="{{ic.printer}}" /></view>
      <view class="printer__body">
        <view class="printer__name">家里的打印机</view>
        <view class="printer__status">● 在线，墨水充足</view>
      </view>
      <view class="printer__tag">已连接</view>
    </view>

    <!-- 待打印列表 -->
    <view class="card">
      <view class="row-between" style="margin-bottom: 20rpx;">
        <text class="title-sm">待打印列表</text>
        <text class="link" bindtap="selectAll">全选</text>
      </view>
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="pitem {{item.selected ? 'pitem--on' : ''}}"
        data-id="{{item.id}}"
        bindtap="toggle"
      >
        <view class="radio {{item.selected ? 'radio--on' : ''}}">
          <view wx:if="{{item.selected}}" class="radio__dot"></view>
        </view>
        <text class="pitem__label">{{item.label}}</text>
        <text class="pitem__tag {{item.type === 'mistake' ? 'pitem__tag--m' : 'pitem__tag--n'}}">
          {{item.type === 'mistake' ? '错题' : '通知'}}
        </text>
      </view>
    </view>

    <!-- 打印设置 -->
    <view class="card">
      <text class="title-sm" style="display:block; margin-bottom: 20rpx;">打印设置</text>
      <view wx:for="{{settings}}" wx:key="label" class="row-between setting-row">
        <text class="muted">{{item.label}}</text>
        <text class="setting-val">{{item.value}}</text>
      </view>
    </view>

    <!-- 成功态 / 发送按钮 -->
    <view wx:if="{{printed}}" class="card success">
      <view class="success__icon"><image class="ic40" src="{{ic.check}}" /></view>
      <view class="success__title">打印任务已发送！</view>
      <view class="success__sub">共 {{selectedCount}} 个文件已发送到打印机，请稍候取件。</view>
      <text class="link" bindtap="reset">再次打印</text>
    </view>
    <button wx:else class="btn-primary" disabled="{{printing || selectedCount === 0}}" bindtap="print">
      <image wx:if="{{!printing}}" class="ic20w" src="{{ic.send}}" />
      {{printing ? '发送中…' : '发送到打印机（' + selectedCount + '）'}}
    </button>
  </view>
</view>
