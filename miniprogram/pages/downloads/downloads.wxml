<view class="tab-pad">
  <view class="header">
    <view class="row-between">
      <view>
        <view class="header__title">文件</view>
        <view class="header__sub">{{dateLabel}} · 共 {{list.length}} 个</view>
      </view>
      <picker mode="date" value="{{date}}" bindchange="onDate">
        <view class="datepick">
          <image class="datepick__ic" src="{{calendarIcon}}" />{{date}}
        </view>
      </picker>
    </view>
  </view>

  <scroll-view wx:if="{{subjects.length > 1}}" scroll-x class="chips">
    <view
      wx:for="{{subjects}}"
      wx:key="*this"
      class="chip {{filter === item ? 'chip--active' : ''}}"
      data-s="{{item}}"
      bindtap="onFilter"
    >{{item}}</view>
  </scroll-view>

  <view class="section-pad gap" style="padding-top: 24rpx;">
    <!-- 骨架屏 -->
    <block wx:if="{{loading}}">
      <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="card dl">
        <view class="skeleton" style="width:80rpx; height:80rpx; border-radius:24rpx"></view>
        <view class="dl__body">
          <view class="skeleton sk-line" style="width:70%"></view>
          <view class="skeleton sk-line" style="width:40%; margin-bottom:0"></view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:elif="{{list.length === 0}}" class="empty">
      <image class="empty__icon" src="{{fileIcon}}" />
      <view class="empty__txt">{{dateLabel}}暂无文件</view>
      <view class="empty__txt" style="font-size:22rpx; margin-top:8rpx;">点右上角日期查看其他日期</view>
    </view>

    <block wx:else>
      <view wx:for="{{list}}" wx:key="id" class="card dl" data-item="{{item}}" bindtap="onDownload">
        <view class="dl__icon" style="background:{{item.wash}}"><image class="dl__img" src="{{item.iconSrc}}" /></view>
        <view class="dl__body">
          <view class="dl__name">{{item.name}}</view>
          <view class="dl__meta muted">
            <text wx:if="{{item.dateText}}">{{item.dateText}} · </text>{{item.sizeText}}
          </view>
        </view>
        <view class="dl__action">去打印</view>
      </view>
    </block>
  </view>
</view>
