.chart-card { padding: 24rpx 28rpx 14rpx; }
.chart-title { font-size: 22rpx; font-weight: 600; color: var(--muted-fg); }
.bar-canvas { width: 100%; height: 190rpx; margin-top: 10rpx; }
.chart-empty { height: 190rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: var(--muted-fg); }

.gen-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.gen-hint { margin-top: 14rpx; font-size: 21rpx; text-align: center; line-height: 1.5; }
.ic20w { width: 32rpx; height: 32rpx; }

.list-wrap { margin-top: 22rpx; }
.list-wrap { padding-bottom: 10rpx; }
.loading-list .mrow,
.mistake-items .mrow { margin-bottom: 16rpx; }
.mrow { display: flex; align-items: center; gap: 18rpx; padding: 24rpx; }
.subject-badge {
  width: 80rpx; height: 80rpx; border-radius: 22rpx; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 22rpx; font-weight: 700;
}
.mrow__body { flex: 1; min-width: 0; }
.mrow__topic { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 27rpx; font-weight: 600; }
.mrow__date { margin-top: 6rpx; font-size: 20rpx; }
.mrow__right { display: flex; align-items: center; gap: 9rpx; flex-shrink: 0; }
.ic16 { width: 27rpx; height: 27rpx; }

.fab {
  position: fixed; right: 38rpx; bottom: calc(env(safe-area-inset-bottom) + 178rpx); z-index: 20;
  width: 104rpx; height: 104rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: var(--primary);
  box-shadow: 0 12rpx 28rpx rgba(13,110,110,0.34);
}
.fab__img { width: 46rpx; height: 46rpx; }
