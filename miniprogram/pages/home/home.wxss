.home-header { padding-bottom: 54rpx; }
.home-header__hello { position: relative; z-index: 1; font-size: 26rpx; color: rgba(255,255,255,0.72); }
.home-header__title { position: relative; z-index: 1; margin-top: 5rpx; font-size: 46rpx; font-weight: 800; letter-spacing: -1rpx; }
.home-header__sub { position: relative; z-index: 1; margin-top: 7rpx; font-size: 22rpx; color: rgba(255,255,255,0.6); }

.stat-row { position: relative; z-index: 1; display: flex; gap: 20rpx; margin-top: 36rpx; }
.stat {
  flex: 1; padding: 23rpx 0; border-radius: 24rpx;
  text-align: center; background: rgba(255,255,255,0.11);
}
.stat__num { font-size: 40rpx; font-weight: 700; color: #fff; }
.stat__lbl { margin-top: 3rpx; font-size: 21rpx; color: rgba(255,255,255,0.7); }

.home-body { margin-top: -16rpx; padding: 0 32rpx; position: relative; z-index: 2; }
.quick-grid { display: flex; justify-content: space-between; }
.quick { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.quick__icon { width: 92rpx; height: 92rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: center; }
.quick__img { width: 41rpx; height: 41rpx; }
.quick__lbl { font-size: 22rpx; font-weight: 500; }

.radar-canvas { width: 100%; height: 400rpx; }
.insight {
  display: flex; align-items: flex-start; gap: 10rpx;
  margin-top: 14rpx; padding: 18rpx 20rpx; border-radius: 20rpx;
  font-size: 21rpx; line-height: 1.55;
}
.insight__ic { width: 27rpx; height: 27rpx; flex-shrink: 0; margin-top: 2rpx; }
.insight--bad { color: #b91c1c; background: #fef2f2; }
.insight--good { color: #15803d; background: #f0fdf4; }

.recent { display: flex; align-items: center; gap: 20rpx; padding: 16rpx 0; }
.recent--div { border-bottom: 1rpx solid var(--divider); }
.recent__body { flex: 1; min-width: 0; }
.recent__topic { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 26rpx; font-weight: 600; }
.recent__date { margin-top: 5rpx; font-size: 20rpx; }

.imsg { display: flex; gap: 17rpx; margin-bottom: 14rpx; padding: 20rpx; border-radius: 21rpx; }
.imsg:last-child { margin-bottom: 0; }
.avatar-sm {
  width: 50rpx; height: 50rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  color: #fff; background: var(--primary); font-size: 21rpx; font-weight: 700;
}
.imsg__body { flex: 1; min-width: 0; }
.imsg__top { display: flex; align-items: center; gap: 10rpx; margin-bottom: 7rpx; }
.imsg__teacher { font-size: 23rpx; font-weight: 600; }
.imsg__tag { margin-left: auto; font-size: 20rpx; font-weight: 600; }
.imsg__content {
  font-size: 22rpx; color: var(--muted-fg); line-height: 1.5;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
