<view class="tab-pad">
  <view class="header">
    <view class="row-between">
      <view>
        <view class="header__title">老师通知</view>
        <view class="header__sub">{{dateLabel}} · 共 {{list.length}} 条</view>
      </view>
      <picker mode="date" value="{{date}}" bindchange="onDate">
        <view class="datepick">
          <image class="datepick__ic" src="{{ic.calendar}}" />{{date}}
        </view>
      </picker>
    </view>
  </view>

  <scroll-view scroll-x class="chips">
    <view
      wx:for="{{filters}}"
      wx:key="key"
      class="chip"
      style="{{filter === item.key ? 'color:#fff;background:' + item.ink : 'color:' + item.ink + ';background:' + item.wash}}"
      data-key="{{item.key}}"
      bindtap="onFilter"
    >{{item.label}}</view>
  </scroll-view>

  <view class="section-pad gap">
    <!-- 骨架屏 -->
    <block wx:if="{{loading}}">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="card">
        <view class="skeleton sk-line" style="width:40%"></view>
        <view class="skeleton sk-line" style="width:100%"></view>
        <view class="skeleton sk-line" style="width:80%; margin-bottom:0"></view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:elif="{{list.length === 0}}" class="empty">
      <image class="empty__icon" src="{{ic.file}}" />
      <view class="empty__txt">{{dateLabel}}暂无消息</view>
      <view class="empty__txt" style="font-size:22rpx; margin-top:8rpx;">点右上角日期查看其他日期</view>
    </view>

    <block wx:else>
      <view wx:for="{{list}}" wx:key="id" class="card msg {{item.important ? 'msg--star' : ''}}">
        <view class="msg__row">
          <view class="avatar">{{item.avatar}}</view>
          <view class="msg__body">
            <view class="msg__top">
              <text class="msg__teacher">{{item.teacher}}</text>
              <image wx:if="{{item.important}}" class="msg__star" src="{{ic.star}}" />
              <text class="msg__tag" style="color:{{item.style.ink}}">[{{item.style.label}}]</text>
            </view>
            <view wx:if="{{item.content}}" class="msg__content">{{item.content}}</view>
            <view wx:if="{{item.imageUrls.length}}" class="msg__imgs">
              <image
                wx:for="{{item.imageUrls}}"
                wx:for-item="img"
                wx:key="*this"
                class="msg__img"
                src="{{img}}"
                mode="aspectFill"
                data-urls="{{item.imageUrls}}"
                data-cur="{{img}}"
                catchtap="previewImage"
              />
            </view>
            <view class="msg__foot">
              <view class="muted msg__time"><image class="ic14" src="{{ic.clock}}" /> {{item.time}}</view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
