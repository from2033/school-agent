# 复制为 .env 并填写。所有项都可留空 —— 留空时走 mock 分支，方便本地直接跑 demo。

# Claude API Key（用于错题 AI 分析）。不填则 AI 走占位文案。
ANTHROPIC_API_KEY=

# JWT 签名密钥。生产请改成随机长串。
JWT_SECRET=dev-secret-change-me

# 微信小程序凭证（用于 wx.login code 换 openid）。不填则用 mock openid，方便本地联调。
WX_APPID=
WX_SECRET=

# QQ 实时监听：由 NapCat 等 OneBot 11 桥接器把群消息 POST 到后端。
# 强烈建议使用专门 QQ 小号；非官方协议存在风控和封号风险。
ONEBOT_ACCESS_TOKEN=change-me
QQ_GROUP_IDS=123456789
QQ_TEACHER_IDS=
QQ_TEACHER_NAME_KEYWORDS=老师
QQ_CAPTURE_ALL=false
